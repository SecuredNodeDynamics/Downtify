{
  "name": "downtify-web",
  "version": "2.10.54",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "VITE_CAPACITOR=1 vite build && cap sync android",
    "android:icons": "npx @capacitor/assets generate --android --iconBackgroundColor '#040000' --splashBackgroundColor '#040000'",
    "android:apk": "cd android && ./gradlew assembleDebug",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "preview": "vite preview",
    "format": "prettier --write src/.",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "axios": "^1.5.0",
    "daisyui": "^4.7.2",
    "uuid": "^14.0.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@iconify/vue": "^4.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "tailwindcss": "^3.3.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  }
}
